function diagnoseMcqFlow() {
  const examId = getConfig_("active_exam_id", "");
  console.log("=== MCQ FLOW DIAGNOSTIC ===");
  console.log("Active exam:", examId);

  // 1. Check MCQ questions
  const questions = readAll_(SHEETS_.QUESTIONS).filter(q => String(q.exam_id) === examId);
  const mcqs = questions.filter(q => {
    const qtype = String(q.qtype || q.section || "").toUpperCase();
    return qtype === "MCQ";
  });

  console.log(`\n--- MCQ QUESTIONS: ${mcqs.length} ---`);
  if (mcqs.length) {
    console.log("First 5 MCQs:");
    mcqs.slice(0, 5).forEach(q => {
      console.log(`  qid: "${q.qid}" | correct_answer: "${q.correct_answer}" | qtype: "${q.qtype}" | section: "${q.section}"`);
    });
  } else {
    console.log("⚠️ NO MCQ QUESTIONS FOUND!");
    console.log("Checking all question types:");
    const qtypes = [...new Set(questions.map(q => q.qtype || q.section || "BLANK"))];
    console.log("  Types found:", qtypes);
  }

  // 2. Check roster
  const roster = readAll_(SHEETS_.ROSTER);
  console.log(`\n--- ROSTER: ${roster.length} students ---`);
  if (roster.length) {
    console.log("First 3 students:");
    roster.slice(0, 3).forEach(r => {
      console.log(`  student_key: "${r.student_key}" | name: ${r.last_name}, ${r.first_name} | class: ${r.class_section}`);
    });
  }

  // 3. Check existing MCQ responses
  const responses = readAll_(SHEETS_.RESPONSES).filter(r => String(r.exam_id) === examId);
  const mcqResponses = responses.filter(r => {
    const qid = String(r.qid || "");
    return mcqs.some(q => String(q.qid) === qid);
  });

  console.log(`\n--- EXISTING MCQ RESPONSES: ${mcqResponses.length} ---`);
  if (mcqResponses.length) {
    console.log("Sample responses:");
    mcqResponses.slice(0, 5).forEach(r => {
      console.log(`  student_key: "${r.student_key}" | qid: "${r.qid}" | mcq_choice: "${r.mcq_choice}"`);
    });
  }

  // 4. Check what api_getQuestions returns
  console.log("\n--- API: api_getQuestions() ---");
  try {
    const apiQuestions = api_getQuestions(examId);
    const apiMcqs = apiQuestions.filter(q => {
      const qtype = String(q.qtype || q.section || "").toUpperCase();
      return qtype === "MCQ";
    });
    console.log(`API returns ${apiQuestions.length} questions, ${apiMcqs.length} MCQs`);

    if (apiMcqs.length === 0 && mcqs.length > 0) {
      console.log("⚠️ API is filtering out MCQs! Check api_getQuestions function.");
    }
  } catch (e) {
    console.log("ERROR:", e.message);
  }

  // 5. Check what api_getRoster returns
  console.log("\n--- API: api_getRoster() ---");
  try {
    const apiRoster = api_getRoster("");
    console.log(`API returns ${apiRoster.length} students`);
  } catch (e) {
    console.log("ERROR:", e.message);
  }

  // 6. Test saving a single MCQ response
  console.log("\n--- TEST: Simulating MCQ save ---");
  if (mcqs.length && roster.length) {
    const testQid = mcqs[0].qid;
    const testStudent = roster[0].student_key;
    console.log(`Would save: student_key="${testStudent}", qid="${testQid}", choice="A"`);

    // Check if the response key format matches
    const existingKey = `${examId}||${testStudent}||${testQid}`;
    console.log(`Response key format: "${existingKey}"`);
  }

  console.log("\n=== DIAGNOSTIC COMPLETE ===");
}

