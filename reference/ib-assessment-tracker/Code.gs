/**
 * Recompute scores for the active exam
 */
function admin_recomputeActiveExam() {
  const examId = getConfig_("active_exam_id", "");
  if (!examId) {
    SpreadsheetApp.getActive().toast("No active exam set. Go to Config sheet and set active_exam_id.", "Error", 5);
    return;
  }
  recomputeExam_(examId, "");
  SpreadsheetApp.getActive().toast(`Recomputed scores for: ${examId}`, "Success", 3);
}

/**
 * Ensure all required sheets exist with correct headers
 */
function admin_ensureSheets() {
  ensureSheets_();
  SpreadsheetApp.getActive().toast("All sheets verified/created.", "Success", 3);
}

/**
 * Remove duplicate responses (keeps the most recent for each student+question)
 */
function admin_deduplicateResponses() {
  const responses = readAll_(SHEETS_.RESPONSES);
  const beforeCount = responses.length;

  // Sort by timestamp ascending (later entries last)
  responses.sort((a, b) => {
    const ta = new Date(a.timestamp || 0);
    const tb = new Date(b.timestamp || 0);
    return ta - tb;
  });

  // Keep only the LAST entry for each (exam_id, student_key, qid)
  const seen = new Map();
  responses.forEach(r => {
    const key = `${r.exam_id}||${r.student_key}||${r.qid}`;
    seen.set(key, r);
  });

  const deduped = Array.from(seen.values());
  const removed = beforeCount - deduped.length;

  writeAll_(SHEETS_.RESPONSES, deduped);
  SpreadsheetApp.getActive().toast(`Removed ${removed} duplicate responses.`, "Success", 3);
}

/**
 * Reset Scores_CurrentExam sheet to correct headers
 * WARNING: This will clear all existing score data!
 */
function admin_resetScoresCurrentExam() {
  const ui = SpreadsheetApp.getUi();
  const response = ui.alert(
    "Reset Scores_CurrentExam?",
    "This will DELETE all data in Scores_CurrentExam and reset the headers. Scores can be regenerated by running Recompute. Continue?",
    ui.ButtonSet.YES_NO
  );

  if (response !== ui.Button.YES) {
    ui.alert("Cancelled.");
    return;
  }

  const ss = SpreadsheetApp.getActive();
  const sheet = ss.getSheetByName(SHEETS_.SCORES_CURRENT);

  if (sheet) {
    // Clear entire sheet
    sheet.clear();

    // Set correct headers
    const headers = HEADERS_[SHEETS_.SCORES_CURRENT];
    sheet.getRange(1, 1, 1, headers.length).setValues([headers]);
    sheet.setFrozenRows(1);

    SpreadsheetApp.getActive().toast("Scores_CurrentExam reset. Run Recompute to regenerate scores.", "Success", 5);
  } else {
    ensureSheets_();
    SpreadsheetApp.getActive().toast("Sheet created with correct headers.", "Success", 3);
  }
}

