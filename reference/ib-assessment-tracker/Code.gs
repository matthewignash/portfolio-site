/**
 * General scoring diagnostic - checks data alignment
 */
function diag_scoring() {
  const examId = getConfig_("active_exam_id", "");
  console.log("=== SCORING DIAGNOSTIC ===");
  console.log("Active exam:", examId);

  // Check Roster
  const roster = readAll_(SHEETS_.ROSTER);
  console.log(`\n--- ROSTER: ${roster.length} students ---`);
  if (roster.length) {
    console.log("Sample (first 3):");
    roster.slice(0, 3).forEach(r => {
      console.log(`  student_key: "${r.student_key}" | class: ${r.class_section}`);
    });
  }

  // Check Responses
  const responses = readAll_(SHEETS_.RESPONSES).filter(r => String(r.exam_id) === examId);
  console.log(`\n--- RESPONSES: ${responses.length} for this exam ---`);
  if (responses.length) {
    console.log("Sample (first 3):");
    responses.slice(0, 3).forEach(r => {
      console.log(`  student_key: "${r.student_key}" | qid: ${r.qid}`);
    });
  }

  // Check Questions
  const questions = readAll_(SHEETS_.QUESTIONS).filter(q => String(q.exam_id) === examId);
  const mcqs = questions.filter(q => String(q.qtype || q.section || "").toUpperCase() === "MCQ");
  const frqs = questions.filter(q => {
    const qtype = String(q.qtype || q.section || "").toUpperCase();
    return qtype === "FRQ" || qtype === "FRQ_PART";
  });
  console.log(`\n--- QUESTIONS: ${questions.length} total (${mcqs.length} MCQ, ${frqs.length} FRQ) ---`);

  // Check key alignment
  console.log("\n--- KEY ALIGNMENT ---");
  if (roster.length && responses.length) {
    const rosterKeys = new Set(roster.map(r => String(r.student_key || "")));
    const responseKeys = new Set(responses.map(r => String(r.student_key || "")));
    const matchCount = [...responseKeys].filter(k => rosterKeys.has(k)).length;

    console.log(`Roster keys: ${rosterKeys.size}`);
    console.log(`Response keys: ${responseKeys.size}`);
    console.log(`Matching: ${matchCount}`);

    if (matchCount === 0) {
      console.log("⚠️ NO KEYS MATCH! Check student_key format.");
    } else {
      console.log("✓ Keys align correctly.");
    }
  }

  // Check Grade Bands
  const bands = readAll_(SHEETS_.GRADE_BANDS).filter(b => String(b.exam_id) === examId);
  console.log(`\n--- GRADE BANDS: ${bands.length} for this exam ---`);

  console.log("\n=== DIAGNOSTIC COMPLETE ===");
}

/**
 * FRQ-specific diagnostic
 */
function diag_frqScoring() {
  const examId = getConfig_("active_exam_id", "");
  console.log("=== FRQ SCORING DIAGNOSTIC ===");
  console.log("Exam:", examId);

  // Get FRQ questions
  const questions = readAll_(SHEETS_.QUESTIONS).filter(q => String(q.exam_id) === examId);
  const frqs = questions.filter(q => {
    const qtype = String(q.qtype || q.section || "").toUpperCase();
    return qtype === "FRQ" || qtype === "FRQ_PART";
  });

  console.log(`\n--- FRQ QUESTIONS: ${frqs.length} ---`);
  frqs.forEach(q => {
    console.log(`  ${q.qid}: max_points=${q.max_points}, scoring_mode=${q.scoring_mode}, strand=${q.strand}`);
  });

  // Get Rubrics
  const rubrics = readAll_(SHEETS_.RUBRICS).filter(r => String(r.exam_id) === examId);
  console.log(`\n--- RUBRICS: ${rubrics.length} items ---`);

  // Group rubrics by qid
  const rubricsByQ = {};
  rubrics.forEach(r => {
    const qid = String(r.qid);
    if (!rubricsByQ[qid]) rubricsByQ[qid] = [];
    rubricsByQ[qid].push(r);
  });

  // Check each FRQ has rubric items
  console.log("\n--- FRQ/RUBRIC ALIGNMENT ---");
  frqs.forEach(q => {
    const qRubrics = rubricsByQ[q.qid] || [];
    const rubricSum = qRubrics.reduce((sum, r) => sum + Number(r.points || 0), 0);
    const maxPts = Number(q.max_points || 0);

    const isOrRubric = rubricSum > maxPts;
    const status = qRubrics.length > 0 ? "✓" : "⚠️ NO RUBRICS";
    const rubricType = isOrRubric ? "(OR)" : "(AND)";

    console.log(`  ${q.qid}: ${qRubrics.length} rubric items, sum=${rubricSum}, max=${maxPts} ${rubricType} ${status}`);
  });

  // Get FRQ Responses
  const responses = readAll_(SHEETS_.RESPONSES).filter(r => String(r.exam_id) === examId);
  const frqQids = new Set(frqs.map(q => String(q.qid)));
  const frqResponses = responses.filter(r => frqQids.has(String(r.qid)));

  console.log(`\n--- FRQ RESPONSES: ${frqResponses.length} ---`);

  // Sample detail_json values
  console.log("\nSample detail_json values:");
  const sampledQids = new Set();
  frqResponses.forEach(r => {
    if (!sampledQids.has(r.qid) && r.detail_json && r.detail_json !== "[]") {
      console.log(`  ${r.qid}: ${r.detail_json}`);
      sampledQids.add(r.qid);
    }
  });

  console.log("\n=== DIAGNOSTIC COMPLETE ===");
}

/**
 * Analyze rubric point structure for checklist questions
 */
function diag_rubricStructure() {
  const examId = getConfig_("active_exam_id", "");
  console.log("=== RUBRIC STRUCTURE ANALYSIS ===\n");

  const questions = readAll_(SHEETS_.QUESTIONS).filter(q =>
    String(q.exam_id) === examId &&
    String(q.scoring_mode) === "checklist"
  );

  const rubrics = readAll_(SHEETS_.RUBRICS).filter(r => String(r.exam_id) === examId);

  console.log(`Checklist questions: ${questions.length}\n`);

  let orCount = 0, andCount = 0, issueCount = 0;

  questions.forEach(q => {
    const qRubrics = rubrics.filter(r => String(r.qid) === String(q.qid));
    const maxPts = Number(q.max_points || 0);
    const rubricItemCount = qRubrics.length;
    const rubricPointSum = qRubrics.reduce((sum, r) => sum + Number(r.points || 0), 0);

    const isOrRubric = rubricPointSum > maxPts;
    const isAndRubric = rubricPointSum === maxPts && rubricItemCount === maxPts;

    let status = "";
    if (isOrRubric) {
      status = "OR rubric";
      orCount++;
    } else if (isAndRubric) {
      status = "AND rubric ✓";
      andCount++;
    } else {
      status = "⚠️ CHECK";
      issueCount++;
    }

    console.log(`${q.qid}: max=${maxPts}, items=${rubricItemCount}, sum=${rubricPointSum} → ${status}`);

    if (!isOrRubric && !isAndRubric) {
      qRubrics.forEach(r => {
        console.log(`    item_id: ${r.item_id} | points: ${r.points}`);
      });
    }
  });

  console.log(`\n--- SUMMARY ---`);
  console.log(`AND rubrics: ${andCount}`);
  console.log(`OR rubrics: ${orCount}`);
  console.log(`Issues: ${issueCount}`);
}

