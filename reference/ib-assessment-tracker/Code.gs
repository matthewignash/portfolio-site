/**
 * Creates the custom menu when the spreadsheet opens
 */
function onOpen() {
  SpreadsheetApp.getUi()
    .createMenu(APP_NAME)
    .addItem("Open grader sidebar", "ui_openSidebar")
    .addSeparator()
    .addSubMenu(SpreadsheetApp.getUi().createMenu("Admin Tools")
      .addItem("Recompute active exam (all classes)", "admin_recomputeActiveExam")
      .addItem("Ensure all sheets exist", "admin_ensureSheets")
      .addSeparator()
      .addItem("Deduplicate responses", "admin_deduplicateResponses")
      .addItem("Reset Scores_CurrentExam headers", "admin_resetScoresCurrentExam"))
    .addSubMenu(SpreadsheetApp.getUi().createMenu("Diagnostics")
      .addItem("Run scoring diagnostic", "diag_scoring")
      .addItem("Run FRQ diagnostic", "diag_frqScoring")
      .addItem("Analyze rubric structure", "diag_rubricStructure"))
    .addToUi();

  // Ensure sheets exist on open
  ensureSheets_();
}

/**
 * Opens the grading sidebar
 */
function ui_openSidebar() {
  const html = HtmlService.createHtmlOutputFromFile("Sidebar")
    .setTitle("IB Chem Grader");
  SpreadsheetApp.getUi().showSidebar(html);
}

// Backward compatibility aliases
function showSidebar() { ui_openSidebar(); }
function setup() { admin_ensureSheets(); }

